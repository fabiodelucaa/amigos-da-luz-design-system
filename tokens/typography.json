{
  "font": {
    "display": {
      "family": "Mokoko",
      "fallback": "Georgia, serif",
      "usage": "Hero titles, show names, institutional headings, poster titles and premium editorial moments"
    },
    "body": {
      "family": "Roboto",
      "fallback": "Arial, Helvetica, sans-serif",
      "usage": "Body text, captions, metadata, buttons, UI labels, forms and practical information"
    }
  },
  "scale": {
    "hero": "clamp(3rem, 7vw, 7rem)",
    "h1": "clamp(2.25rem, 5vw, 4.5rem)",
    "h2": "clamp(1.75rem, 3vw, 3rem)",
    "h3": "1.5rem",
    "bodyLarge": "1.25rem",
    "body": "1rem",
    "small": "0.875rem"
  },
  "lineHeight": {
    "display": 1.05,
    "heading": 1.15,
    "body": 1.6,
    "compact": 1.35
  }
}
